{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SymbolDefinition",
  "description": "Complete symbol definition for custom electrical symbols",
  "type": "object",
  "required": [
    "id",
    "name",
    "version",
    "category",
    "createdAt",
    "updatedAt",
    "width",
    "height",
    "graphics",
    "pins",
    "properties"
  ],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier"
    },
    "name": {
      "type": "string",
      "description": "Display name"
    },
    "version": {
      "type": "string",
      "description": "Semantic version",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "description": {
      "type": "string",
      "description": "Optional description"
    },
    "category": {
      "type": "string",
      "description": "Category (e.g., relay, switch, sensor)"
    },
    "author": {
      "type": "string",
      "description": "Author name"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "Creation timestamp (ISO 8601)"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "Last modification timestamp (ISO 8601)"
    },
    "width": {
      "type": "integer",
      "multipleOf": 20,
      "description": "Symbol width in pixels (multiple of 20)"
    },
    "height": {
      "type": "integer",
      "multipleOf": 20,
      "description": "Symbol height in pixels (multiple of 20)"
    },
    "graphics": {
      "type": "array",
      "description": "Graphics for the symbol",
      "items": {
        "$ref": "#/definitions/GraphicPrimitive"
      }
    },
    "pins": {
      "type": "array",
      "description": "Pins on the symbol",
      "items": {
        "$ref": "#/definitions/SymbolPin"
      }
    },
    "units": {
      "type": "array",
      "maxItems": 4,
      "description": "Optional multi-unit definitions",
      "items": {
        "$ref": "#/definitions/SymbolUnit"
      }
    },
    "properties": {
      "type": "array",
      "description": "Configurable properties",
      "items": {
        "$ref": "#/definitions/SymbolProperty"
      }
    },
    "runtimeStateSchema": {
      "type": "object",
      "description": "Optional runtime state schema (JSON Schema)"
    },
    "visualStates": {
      "type": "object",
      "description": "Optional state-driven visual variants",
      "additionalProperties": {
        "$ref": "#/definitions/SymbolVisualVariant"
      }
    },
    "animations": {
      "type": "object",
      "description": "Optional per-state symbol animations",
      "additionalProperties": {
        "type": "array",
        "items": {
          "$ref": "#/definitions/SymbolAnimationSpec"
        }
      }
    },
    "extendsSymbol": {
      "type": "string",
      "description": "ID of parent symbol for inheritance"
    },
    "spice": {
      "$ref": "#/definitions/SpiceModelRef",
      "description": "SPICE model reference"
    },
    "iecSection": {
      "type": "string",
      "description": "IEC 60617 section code"
    },
    "iecCategory": {
      "type": "string",
      "description": "IEC 60617 category"
    },
    "refDesignator": {
      "type": "string",
      "description": "Reference designator prefix (e.g., R, C, K)"
    },
    "pinNumbersHidden": {
      "type": "boolean",
      "description": "Hide pin numbers globally"
    },
    "pinNamesHidden": {
      "type": "boolean",
      "description": "Hide pin names globally"
    },
    "pinNameOffset": {
      "type": "number",
      "description": "Pin name offset in pixels"
    },
    "excludeFromSim": {
      "type": "boolean",
      "description": "Exclude from simulation"
    }
  },
  "definitions": {
    "PinElectricalTypeV2": {
      "type": "string",
      "enum": [
        "input", "output", "bidirectional", "tri_state",
        "passive", "power_in", "power_out",
        "open_collector", "open_emitter",
        "free", "unspecified", "no_connect"
      ],
      "description": "KiCad-compatible electrical pin type (12 values)"
    },
    "PinFunctionalRole": {
      "type": "string",
      "enum": ["general", "plc_input", "plc_output", "communication"],
      "description": "PLC functional role"
    },
    "PinShapeV2": {
      "type": "string",
      "enum": [
        "line", "inverted", "clock", "inverted_clock",
        "input_low", "clock_low", "output_low",
        "edge_clock_high", "non_logic"
      ],
      "description": "KiCad-compatible pin shape (9 values)"
    },
    "SymbolPinV2": {
      "type": "object",
      "required": ["id", "name", "number", "electricalType", "shape", "position", "orientation", "length", "sortOrder"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "number": { "type": "string" },
        "electricalType": { "$ref": "#/definitions/PinElectricalTypeV2" },
        "functionalRole": { "$ref": "#/definitions/PinFunctionalRole" },
        "shape": { "$ref": "#/definitions/PinShapeV2" },
        "position": {
          "type": "object",
          "required": ["x", "y"],
          "properties": { "x": { "type": "number" }, "y": { "type": "number" } }
        },
        "orientation": { "type": "string", "enum": ["right", "left", "up", "down"] },
        "length": { "type": "number" },
        "sortOrder": { "type": "integer" },
        "nameVisible": { "type": "boolean" },
        "numberVisible": { "type": "boolean" },
        "hidden": { "type": "boolean" },
        "description": {
          "type": "string",
          "description": "v3: Human-readable description / tooltip text"
        },
        "group": {
          "type": "string",
          "description": "v3: Logical group label (e.g. 'Power', 'Data')"
        },
        "locked": {
          "type": "boolean",
          "description": "v3: Lock state — blocks drag/delete when true"
        },
        "color": {
          "type": "string",
          "description": "v3: CSS fill color override (stroke retains default)"
        },
        "labelOffset": {
          "type": "object",
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" }
          },
          "required": ["x", "y"],
          "description": "v3: Pixel offset of the port name label from default position"
        }
      }
    },
    "SpicePinMapping": {
      "type": "object",
      "required": ["pinNumber", "spiceNode"],
      "properties": {
        "pinNumber": { "type": "string" },
        "spiceNode": { "type": "string" }
      }
    },
    "SpiceModelRef": {
      "type": "object",
      "required": ["device", "pinMapping"],
      "properties": {
        "device": { "type": "string" },
        "type": { "type": "string" },
        "library": { "type": "string" },
        "name": { "type": "string" },
        "pinMapping": {
          "type": "array",
          "items": { "$ref": "#/definitions/SpicePinMapping" }
        },
        "params": {
          "type": "object",
          "additionalProperties": {
            "oneOf": [{ "type": "string" }, { "type": "number" }]
          }
        }
      }
    },
    "SymbolPin": {
      "type": "object",
      "required": [
        "id",
        "name",
        "number",
        "type",
        "shape",
        "position",
        "orientation",
        "length"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for this pin"
        },
        "name": {
          "type": "string",
          "description": "Display name of the pin"
        },
        "number": {
          "type": "string",
          "description": "Pin number (e.g., '1', 'A1')"
        },
        "type": {
          "type": "string",
          "enum": [
            "input",
            "output",
            "bidirectional",
            "power",
            "passive"
          ],
          "description": "Electrical type"
        },
        "shape": {
          "type": "string",
          "enum": [
            "line",
            "inverted",
            "clock"
          ],
          "description": "Visual shape"
        },
        "position": {
          "type": "object",
          "required": [
            "x",
            "y"
          ],
          "properties": {
            "x": {
              "type": "number"
            },
            "y": {
              "type": "number"
            }
          },
          "description": "Position relative to symbol origin"
        },
        "orientation": {
          "type": "string",
          "enum": [
            "right",
            "left",
            "up",
            "down"
          ],
          "description": "Pin orientation"
        },
        "length": {
          "type": "number",
          "description": "Pin line length in pixels"
        },
        "hidden": {
          "type": "boolean",
          "description": "Whether pin is hidden from display"
        },
        "electricalType": {
          "$ref": "#/definitions/PinElectricalTypeV2",
          "description": "v2: KiCad-compatible electrical type"
        },
        "functionalRole": {
          "$ref": "#/definitions/PinFunctionalRole",
          "description": "v2: PLC functional role"
        },
        "sortOrder": {
          "type": "integer",
          "description": "v2: Sort order for pin numbering"
        },
        "nameVisible": {
          "type": "boolean",
          "description": "v2: Whether pin name is visible"
        },
        "numberVisible": {
          "type": "boolean",
          "description": "v2: Whether pin number is visible"
        },
        "description": {
          "type": "string",
          "description": "v3: Human-readable description / tooltip text"
        },
        "group": {
          "type": "string",
          "description": "v3: Logical group label (e.g. 'Power', 'Data')"
        },
        "locked": {
          "type": "boolean",
          "description": "v3: Lock state — blocks drag/delete when true"
        },
        "color": {
          "type": "string",
          "description": "v3: CSS fill color override (stroke retains default)"
        },
        "labelOffset": {
          "type": "object",
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" }
          },
          "required": ["x", "y"],
          "description": "v3: Pixel offset of the port name label from default position"
        }
      }
    },
    "GraphicPrimitive": {
      "oneOf": [
        {
          "$ref": "#/definitions/RectPrimitive"
        },
        {
          "$ref": "#/definitions/CirclePrimitive"
        },
        {
          "$ref": "#/definitions/PolylinePrimitive"
        },
        {
          "$ref": "#/definitions/ArcPrimitive"
        },
        {
          "$ref": "#/definitions/TextPrimitive"
        }
      ]
    },
    "SymbolVisualTransform": {
      "type": "object",
      "properties": {
        "translateX": { "type": "number" },
        "translateY": { "type": "number" },
        "rotation": { "type": "number" },
        "scaleX": { "type": "number" },
        "scaleY": { "type": "number" },
        "pivotX": { "type": "number" },
        "pivotY": { "type": "number" }
      }
    },
    "GraphicPrimitiveOverride": {
      "type": "object",
      "properties": {
        "visible": { "type": "boolean" },
        "opacity": { "type": "number" },
        "stroke": { "type": "string" },
        "fill": { "type": "string" },
        "strokeWidth": { "type": "number" },
        "text": { "type": "string" },
        "fontSize": { "type": "number" },
        "fontFamily": { "type": "string" },
        "anchor": {
          "type": "string",
          "enum": ["start", "middle", "end"]
        },
        "transform": {
          "$ref": "#/definitions/SymbolVisualTransform"
        }
      }
    },
    "SymbolVisualVariant": {
      "type": "object",
      "properties": {
        "graphics": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/GraphicPrimitive"
          }
        },
        "primitiveOverrides": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/GraphicPrimitiveOverride"
          }
        }
      }
    },
    "SymbolAnimationSpec": {
      "type": "object",
      "required": ["type", "target"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["rotate"]
        },
        "target": {
          "type": "string"
        },
        "speed": {
          "type": "number"
        },
        "pivot": {
          "type": "object",
          "required": ["x", "y"],
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" }
          }
        }
      }
    },
    "RectPrimitive": {
      "type": "object",
      "required": [
        "kind",
        "x",
        "y",
        "width",
        "height",
        "stroke",
        "fill",
        "strokeWidth"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "const": "rect"
        },
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "width": {
          "type": "number"
        },
        "height": {
          "type": "number"
        },
        "stroke": {
          "type": "string"
        },
        "fill": {
          "type": "string"
        },
        "strokeWidth": {
          "type": "number"
        }
      }
    },
    "CirclePrimitive": {
      "type": "object",
      "required": [
        "kind",
        "cx",
        "cy",
        "r",
        "stroke",
        "fill",
        "strokeWidth"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "const": "circle"
        },
        "cx": {
          "type": "number"
        },
        "cy": {
          "type": "number"
        },
        "r": {
          "type": "number"
        },
        "stroke": {
          "type": "string"
        },
        "fill": {
          "type": "string"
        },
        "strokeWidth": {
          "type": "number"
        }
      }
    },
    "PolylinePrimitive": {
      "type": "object",
      "required": [
        "kind",
        "points",
        "stroke",
        "fill",
        "strokeWidth"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "const": "polyline"
        },
        "points": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "x",
              "y"
            ],
            "properties": {
              "x": {
                "type": "number"
              },
              "y": {
                "type": "number"
              }
            }
          }
        },
        "stroke": {
          "type": "string"
        },
        "fill": {
          "type": "string"
        },
        "strokeWidth": {
          "type": "number"
        }
      }
    },
    "ArcPrimitive": {
      "type": "object",
      "required": [
        "kind",
        "cx",
        "cy",
        "r",
        "startAngle",
        "endAngle",
        "stroke",
        "fill",
        "strokeWidth"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "const": "arc"
        },
        "cx": {
          "type": "number"
        },
        "cy": {
          "type": "number"
        },
        "r": {
          "type": "number"
        },
        "startAngle": {
          "type": "number"
        },
        "endAngle": {
          "type": "number"
        },
        "stroke": {
          "type": "string"
        },
        "fill": {
          "type": "string"
        },
        "strokeWidth": {
          "type": "number"
        }
      }
    },
    "TextPrimitive": {
      "type": "object",
      "required": [
        "kind",
        "x",
        "y",
        "text",
        "fontSize",
        "fontFamily",
        "fill"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "const": "text"
        },
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "text": {
          "type": "string"
        },
        "fontSize": {
          "type": "number"
        },
        "fontFamily": {
          "type": "string"
        },
        "fill": {
          "type": "string"
        },
        "anchor": {
          "type": "string",
          "enum": [
            "start",
            "middle",
            "end"
          ]
        }
      }
    },
    "SymbolUnit": {
      "type": "object",
      "required": [
        "unitId",
        "name",
        "graphics",
        "pins"
      ],
      "properties": {
        "unitId": {
          "type": "integer",
          "description": "Unit identifier (1-based)"
        },
        "name": {
          "type": "string",
          "description": "Unit name (e.g., 'A', 'B', 'Unit 1')"
        },
        "graphics": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/GraphicPrimitive"
          }
        },
        "pins": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/SymbolPin"
          }
        }
      }
    },
    "SymbolProperty": {
      "type": "object",
      "required": [
        "key",
        "value",
        "type"
      ],
      "properties": {
        "key": {
          "type": "string",
          "description": "Property key (e.g., 'voltage', 'color')"
        },
        "value": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "number"
            },
            {
              "type": "boolean"
            }
          ],
          "description": "Default value"
        },
        "type": {
          "type": "string",
          "enum": [
            "string",
            "number",
            "boolean",
            "enum"
          ],
          "description": "Property type"
        },
        "visible": {
          "type": "boolean",
          "description": "Whether property is visible in UI"
        },
        "editorType": {
          "type": "string",
          "enum": [
            "text",
            "number",
            "checkbox",
            "select"
          ],
          "description": "Editor widget type"
        },
        "options": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Options for enum/select types"
        }
      }
    }
  }
}
