<?xml version="1.0" encoding="UTF-8"?>
<ms:SymbolDefinition
  xmlns:ms="http://modone.io/schema/symbol/1.0"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://modone.io/schema/symbol/1.0 ../../symbol-schema/modone-symbol.xsd"
  id="builtin:button"
  name="Button"
  version="1.0.0"
  domain="circuit"
  placeable="true">

  <ms:Description>Pushbutton contact</ms:Description>
  <ms:Category>control</ms:Category>
  <ms:Author>ModOne</ms:Author>
  <ms:CreatedAt>2026-03-05T00:00:00Z</ms:CreatedAt>
  <ms:UpdatedAt>2026-03-05T00:00:00Z</ms:UpdatedAt>

  <ms:Layout width="40" height="40" unit="px"/>

  <ms:Ports>
    <ms:Port id="in" name="IN" number="1"
      electricalType="input" functionalRole="general"
      shape="line" orientation="left"
      x="0" y="20" length="0" sortOrder="1"
      nameVisible="true" numberVisible="true"/>
    <ms:Port id="out" name="OUT" number="2"
      electricalType="output" functionalRole="general"
      shape="line" orientation="right"
      x="40" y="20" length="0" sortOrder="2"
      nameVisible="true" numberVisible="true"/>
  </ms:Ports>

  <ms:Graphics>
    <ms:Polyline id="lead-in" stroke="#888" fill="none" strokeWidth="2">
      <ms:Point x="0" y="20"/>
      <ms:Point x="14" y="20"/>
    </ms:Polyline>
    <ms:Polyline id="contact-arm" stroke="#888" fill="none" strokeWidth="2">
      <ms:Point x="14" y="24"/>
      <ms:Point x="26" y="16"/>
    </ms:Polyline>
    <ms:Polyline id="lead-out" stroke="#888" fill="none" strokeWidth="2">
      <ms:Point x="26" y="20"/>
      <ms:Point x="40" y="20"/>
    </ms:Polyline>
    <ms:Polyline id="plunger-head" stroke="#888" fill="none" strokeWidth="1.5">
      <ms:Point x="14" y="10"/>
      <ms:Point x="26" y="10"/>
    </ms:Polyline>
  </ms:Graphics>

  <ms:Properties>
    <ms:Property key="mode" type="string" editorType="text" visible="true">
      <ms:DefaultValue>momentary</ms:DefaultValue>
    </ms:Property>
    <ms:Property key="contactConfig" type="string" editorType="text" visible="true">
      <ms:DefaultValue>1a</ms:DefaultValue>
    </ms:Property>
    <ms:Property key="pressed" type="boolean" editorType="checkbox" visible="true">
      <ms:DefaultValue>false</ms:DefaultValue>
    </ms:Property>
  </ms:Properties>

  <ms:Behavior templateId="archetype:switch" archetype="switch" interactionMode="momentary" deviceScoped="false">
    <ms:TerminalRoles>
      <ms:TerminalRole portId="in" role="IN"/>
      <ms:TerminalRole portId="out" role="OUT"/>
    </ms:TerminalRoles>
  </ms:Behavior>

  <ms:VisualStates>
    <ms:VisualState name="pressed">
    </ms:VisualState>
  </ms:VisualStates>

</ms:SymbolDefinition>