<?xml version="1.0" encoding="UTF-8"?>
<ms:SymbolDefinition
  xmlns:ms="http://modone.io/schema/symbol/1.0"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://modone.io/schema/symbol/1.0 ../../symbol-schema/modone-symbol.xsd"
  id="builtin:selector_switch"
  name="Selector Switch"
  version="1.0.0"
  domain="circuit"
  placeable="true">

  <ms:Description>Two-position selector switch</ms:Description>
  <ms:Category>control</ms:Category>
  <ms:Author>ModOne</ms:Author>
  <ms:CreatedAt>2026-03-05T00:00:00Z</ms:CreatedAt>
  <ms:UpdatedAt>2026-03-05T00:00:00Z</ms:UpdatedAt>

  <ms:Layout width="40" height="40" unit="mm"/>

  <ms:Ports>
    <ms:Port id="com" name="COM" number="C"
      type="input" electricalType="input" functionalRole="general"
      shape="line" orientation="left"
      x="0" y="10" length="0" sortOrder="1"
      nameVisible="true" numberVisible="true"/>
    <ms:Port id="pos1" name="1" number="1"
      type="output" electricalType="output" functionalRole="general"
      shape="line" orientation="right"
      x="40" y="10" length="0" sortOrder="2"
      nameVisible="true" numberVisible="true"/>
    <ms:Port id="pos2" name="2" number="2"
      type="output" electricalType="output" functionalRole="general"
      shape="line" orientation="right"
      x="40" y="20" length="0" sortOrder="3"
      nameVisible="true" numberVisible="true"/>
  </ms:Ports>

  <ms:Graphics>
    <ms:Polyline id="lead-in" stroke="#888" fill="none" strokeWidth="1">
      <ms:Point x="0" y="10"/>
      <ms:Point x="10" y="10"/>
    </ms:Polyline>
    <ms:Circle id="selector-body" cx="16" cy="10" r="5" stroke="#888" fill="transparent" strokeWidth="1"/>
    <ms:Polyline id="selector-arm" stroke="#888" fill="none" strokeWidth="1">
      <ms:Point x="16" y="10"/>
      <ms:Point x="28" y="6"/>
    </ms:Polyline>
    <ms:Polyline id="pos1-lead" stroke="#888" fill="none" strokeWidth="1">
      <ms:Point x="28" y="10"/>
      <ms:Point x="40" y="10"/>
    </ms:Polyline>
    <ms:Polyline id="pos2-lead" stroke="#888" fill="none" strokeWidth="1">
      <ms:Point x="28" y="20"/>
      <ms:Point x="40" y="20"/>
    </ms:Polyline>
  </ms:Graphics>

  <ms:Properties>
    <ms:Property key="designation" type="string" editorType="text" visible="true">
      <ms:DefaultValue>S1</ms:DefaultValue>
    </ms:Property>
    <ms:Property key="positions" type="number" editorType="number" visible="true">
      <ms:DefaultValue>2</ms:DefaultValue>
    </ms:Property>
    <ms:Property key="currentPosition" type="number" editorType="number" visible="true">
      <ms:DefaultValue>0</ms:DefaultValue>
    </ms:Property>
    <ms:Property key="maintained" type="boolean" editorType="checkbox" visible="true">
      <ms:DefaultValue>true</ms:DefaultValue>
    </ms:Property>
  </ms:Properties>

  <ms:Behavior templateId="archetype:switch" archetype="switch" interactionMode="maintained" deviceScoped="false">
    <ms:TerminalRoles>
      <ms:TerminalRole portId="com" role="COM"/>
      <ms:TerminalRole portId="pos1" role="NO"/>
      <ms:TerminalRole portId="pos2" role="NC"/>
    </ms:TerminalRoles>
  </ms:Behavior>

  <ms:VisualStates>
    <ms:VisualState name="open">
      <ms:PrimitiveOverrides>
        <ms:Override targetId="selector-arm">
          <ms:Transform translateX="-4" translateY="4"/>
        </ms:Override>
      </ms:PrimitiveOverrides>
    </ms:VisualState>
    <ms:VisualState name="closed">
      <ms:PrimitiveOverrides>
        <ms:Override targetId="selector-body" stroke="#eab308" fill="#fef3c7"/>
        <ms:Override targetId="selector-arm" stroke="#d97706"/>
      </ms:PrimitiveOverrides>
    </ms:VisualState>
  </ms:VisualStates>

</ms:SymbolDefinition>
